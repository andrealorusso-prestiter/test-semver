#!/bin/bash

###############################################################################
# Conventional Commits validation
# Tipi ammessi: feat, fix, refactor, perf, style, test, docs, build, ops, chore
# Breaking change: qualsiasi tipo con ! (es. feat!:, fix(api)!:)
###############################################################################

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits
if git rev-parse -q --verify MERGE_HEAD > /dev/null 2>&1; then
    exit 0
fi

# Skip merge commit messages generated by Git
if echo "$COMMIT_MSG" | grep -qE "^Merge (branch|pull request|remote-tracking branch)"; then
    exit 0
fi

PATTERN="^(feat|fix|refactor|perf|style|test|docs|build|ops|chore)(\(.+\))?!?: .+"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "  Commit annullato: il messaggio non rispetta il formato Conventional Commits."
    echo ""
    echo "  Formato atteso:  <tipo>[(<scope>)][!]: <descrizione>"
    echo "  Tipi ammessi:    feat | fix | refactor | perf | style | test | docs | build | ops | chore"
    echo "  Breaking change: aggiungi ! prima dei due punti (es. feat!: o feat(api)!:)"
    echo ""
    echo "  Esempi validi:"
    echo "    feat: aggiunta validazione email nel form cliente"
    echo "    fix: corretto calcolo importo residuo con IVA"
    echo "    chore: aggiornamento dipendenze composer"
    echo "    docs: aggiornata documentazione API pratiche"
    echo "    refactor: estratto Service_RataService da MonitoringController"
    echo "    perf: ottimizzata query lista pratiche con indice composito"
    echo "    feat(api)!: rimosso endpoint deprecato /api/v1/lead"
    echo "    fix!: modificata firma calcolaImporto()"
    echo ""
    echo "  Messaggio ricevuto: \"$COMMIT_MSG\""
    echo ""
    exit 1
fi

exit 0
